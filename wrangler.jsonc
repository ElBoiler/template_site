{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "myinternetface",
  "compatibility_date": "2025-09-27",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": "."
  },
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "kv_namespaces": [
    {
      // Create a KV namespace in Cloudflare dashboard → Workers & Pages → KV
      // Then paste the namespace ID here
      "binding": "BDS_CONTENT",
      "id": "0231215d7d7b4e80a433c9245e220c9e"
    }
  ]
}
